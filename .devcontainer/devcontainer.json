{
  "name": "FWMS Container",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:16",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Next.js App",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "remote.autoForwardPortsSource": "process",
        "remote.autoForwardPortsFallback": 0
      }
    }
  }
}