// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}
enum Role {
  ADMIN
  HR
  EMPLOYEE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  READ
}

enum OrgNodeLevel {
  GROUP
  LEGAL_ENTITY
  BUSINESS_UNIT
  DEPARTMENT
  BRANCH
  COST_CENTER
}

enum DocumentType {
  PASSPORT
  VISA
  CONTRACT
  PERMIT
  CERTIFICATE
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum VisaStatus {
  ACTIVE
  EXPIRED
  RENEWING
  CANCELLED
}

enum ExpatStatus {
  ONBOARDING
  ACTIVE
  RELOCATION
  RENEWAL_PENDING
  TERMINATING
  TERMINATED
}

enum ContractStatus {
  ACTIVE
  TERMINATED
  EXPIRED
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
}

enum AllowanceType {
  HOUSING
  EDUCATION
  HARDSHIP
  COLA
  TRANSPORT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

enum RuleType {
  VISA
  MEDICAL
  PASSPORT
  CONTRACT
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  domain    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  employees       Employee[]
  documents       Document[]
  visas           Visa[]
  contracts       Contract[]
  payrolls        Payroll[]
  attendances     Attendance[]
  complianceRules ComplianceRule[]
  expatriates     Expatriate[]
  terminations    Termination[]
  geofences       Geofence[]
  orgNodes        OrgNode[]
  auditTrails     AuditTrail[]
  sops            Sop[]
  candidates      Candidate[]

  @@map("tenants")
}


model ComplianceRule {
  id              String                       @id @default(cuid())
  tenantId        String
  tenant          Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  country         String // ISO code e.g. "MY"
  ruleType        RuleType
  validityMonths  Int
  alertDays       Int                          @default(60)
  renewalLeadTime Int                          @default(30)
  description     String?
  active          Boolean                      @default(true)
  ruleEmbedding   Unsupported("vector(384)")?
  tags            String[]
  weaviateId      String?                      @unique
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  @@unique([tenantId, country, ruleType])
  @@map("compliance_rules")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  role         Role          @default(EMPLOYEE)
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee     Employee?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  terminations Termination[]

  @@map("users")
}

model AuditTrail {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType     String
  entityId       String
  action         AuditAction
  actorId        String?
  actorRole      Role?
  previousValue  Json?
  newValue       Json?
  metadata       Json?
  createdAt      DateTime    @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([createdAt])
  @@map("audit_trail")
}

model OrgNode {
  id           String      @id @default(cuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       OrgNode?    @relation("OrgNodeHierarchy", fields: [parentId], references: [id])
  children     OrgNode[]   @relation("OrgNodeHierarchy")
  level        OrgNodeLevel
  name         String
  code         String?
  currency     String?
  locale       String?
  country      String?
  isActive     Boolean     @default(true)
  status       String?     @default("ACTIVE")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([tenantId, level])
  @@map("org_nodes")
}

model Employee {
  id            String                       @id @default(cuid())
  tenantId      String
  tenant        Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String?                      @unique
  user          User?                        @relation(fields: [userId], references: [id])
  name          String
  email         String
  phone         String?
  address       String?
  dateOfBirth   DateTime?
  nationality   String?
  country       String? // e.g. "MY", "SG", "ID"
  isForeign     Boolean                      @default(false)
  position      String?
  department    String?
  hireDate      DateTime?
  nameEmbedding Unsupported("vector(384)")?
  tags          String[]
  weaviateId    String?                      @unique
  vectorScore   Float?
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt

  documents        Document[]
  visas            Visa[]
  contracts        Contract[]
  payrolls         Payroll[]
  attendances      Attendance[]
  expatriate       Expatriate?
  terminations     Termination[]
  locationRecords  LocationRecord[]
  locationAlerts   LocationAlert[]
  locationSettings WorkerLocationSettings?
  emergencyAlerts  EmergencyAlert[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@map("employees")
}

model Document {
  id               String                       @id @default(cuid())
  tenantId         String
  tenant           Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee                     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type             DocumentType
  fileUrl          String
  contentText      String? // OCR/extracted text for embedding
  expiryDate       DateTime?
  status           DocumentStatus               @default(PENDING)
  contentEmbedding Unsupported("vector(1536)")?
  tags             String[]
  weaviateId       String?                      @unique
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([tenantId, employeeId])
  @@index([status, expiryDate])
  @@map("documents")
}

model Visa {
  id            String                       @id @default(cuid())
  tenantId      String
  tenant        Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee                     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type          String
  number        String                       @unique
  country       String? // e.g. "Malaysia"
  issueDate     DateTime
  expiryDate    DateTime
  status        VisaStatus                   @default(ACTIVE)
  visaEmbedding Unsupported("vector(384)")?
  tags          String[]
  weaviateId    String?                      @unique
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt

  @@index([tenantId, expiryDate, status])
  @@map("visas")
}

model Expatriate {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId     String      @unique
  employee       Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  status         ExpatStatus @default(ONBOARDING)
  relocationInfo Json? // {originCountry, arrivalDate, orientationCompleted}
  taxInfo        Json? // {taxResidency, pcbBracket, epfEligible}
  allowances     Json[] // array of {type, amount, currency}
  workflows      String[] // workflow IDs
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([tenantId, status])
  @@map("expatriates")
}

model Contract {
  id         String         @id @default(cuid())
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String
  startDate  DateTime
  endDate    DateTime?
  salary     Decimal
  terms      String
  status     ContractStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@map("contracts")
}

model Payroll {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  basicSalary Decimal
  allowances  Json? // {"housing": 1000, "cola": 500, "currency": "MYR"}
  deductions  Decimal       @default(0)
  netSalary   Decimal
  status      PayrollStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("payrolls")
}

enum PayrollRunStatus {
  DRAFT
  LOCKED
  CALCULATING
  CALCULATED
  FINALIZED
  CANCELLED
}

model PayrollRun {
  id            String          @id @default(cuid())
  tenantId      String
  legalEntityId String?
  periodStart   DateTime
  periodEnd     DateTime
  status        PayrollRunStatus @default(DRAFT)
  lockedAt      DateTime?
  finalizedAt   DateTime?
  checksum      String?
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  lineItems     PayrollLineItem[]

  @@unique([tenantId, legalEntityId, periodStart, periodEnd])
  @@index([tenantId, status])
  @@map("payroll_runs")
}

model PayrollLineItem {
  id            String   @id @default(cuid())
  runId         String
  run           PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  employeeId    String
  componentType String
  amount        Decimal
  currency      String   @default("MYR")
  isTaxable     Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([runId, employeeId])
  @@map("payroll_line_items")
}

model LeavePolicy {
  id                String    @id @default(cuid())
  tenantId          String
  legalEntityId     String?
  leaveType         String
  annualEntitlement Decimal
  carryForwardMax   Decimal   @default(0)
  encashmentRate    Decimal   @default(1)
  statutoryMinimum  Decimal   @default(0)
  statutorySource   String?
  accrualMethod     String    @default("MONTHLY")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([tenantId, legalEntityId, leaveType])
  @@map("leave_policies")
}

model LeaveBalance {
  id           String   @id @default(cuid())
  tenantId     String
  employeeId   String
  leaveType    String
  year         Int
  entitlement  Decimal  @default(0)
  used         Decimal  @default(0)
  pending      Decimal  @default(0)
  carryForward Decimal  @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, employeeId, leaveType, year])
  @@map("leave_balances")
}

model WorkflowDefinition {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  version   Int      @default(1)
  module    String
  graphJson Json
  slaConfig Json?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instances WorkflowInstance[]

  @@unique([tenantId, name, version])
  @@map("workflow_definitions")
}

model WorkflowInstance {
  id            String             @id @default(cuid())
  tenantId      String
  definitionId  String
  definition    WorkflowDefinition @relation(fields: [definitionId], references: [id])
  entityType    String
  entityId      String
  status        String             @default("ACTIVE")
  currentStepId String?
  context       Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  steps WorkflowInstanceStep[]

  @@index([tenantId, status])
  @@index([tenantId, entityType, entityId])
  @@map("workflow_instances")
}

model WorkflowInstanceStep {
  id           String           @id @default(cuid())
  instanceId   String
  instance     WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepId       String
  stepName     String
  assigneeId   String?
  assigneeRole String?
  status       String           @default("PENDING")
  decidedBy    String?
  decision     String?
  comment      String?
  slaDeadline  DateTime?
  decidedAt    DateTime?
  createdAt    DateTime         @default(now())

  @@index([instanceId, status])
  @@map("workflow_instance_steps")
}

model NotificationPreference {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  channel     String
  eventType   String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, userId, channel, eventType])
  @@map("notification_preferences")
}
model Attendance {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  hoursWorked Decimal?
  status      AttendanceStatus @default(PRESENT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("attendances")
}

enum TerminationType {
  RESIGNATION
  VOLUNTARY
  REDUNDANCY
  DISCIPLINARY
  RETIREMENT
  CONTRACT_END
}

enum HandoverStatus {
  COMPLETE
  IN_PROGRESS
  PENDING
}

model Termination {
  id                 String          @id @default(cuid())
  tenantId           String
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId         String
  employee           Employee        @relation(fields: [employeeId], references: [id])
  approverId         String?
  approver           User?           @relation(fields: [approverId], references: [id])
  terminationType    TerminationType
  lastWorkingDay     DateTime
  reason             String
  noticePeriodServed Boolean         @default(false)
  finalSalaryAmount  Decimal         @default(0)
  pendingLeave       Float?
  otherPayments      Float?
  exitInterviewNotes String?
  handoverStatus     HandoverStatus  @default(PENDING)
  status             String          @default("PENDING")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([tenantId])
  @@index([employeeId])
  @@map("terminations")
}

enum LocationSource {
  GPS
  NETWORK
  MANUAL
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertType {
  UNAUTHORIZED_EXIT
  RESTRICTED_ENTRY
  SOS
  OFFLINE
  GEO_FENCE_VIOLATION
}

enum EmergencyType {
  SOS
  PANIC
  MEDICAL
  ACCIDENT
}

enum SopCategory {
  POLICY
  OPERATIONAL
  COMPLIANCE
  EMERGENCY
}

enum SopStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum SopApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  VOID
}

enum SopArtifactType {
  MARKDOWN
  HTML
  DOCX
  PDF
  MERMAID
}

model Sop {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department    String
  code          String
  title         String
  category      SopCategory
  status        SopStatus      @default(DRAFT)
  currentVersion Int           @default(1)
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  versions SopVersion[]

  @@unique([tenantId, code])
  @@index([tenantId, department])
  @@map("sops")
}

model SopVersion {
  id              String   @id @default(cuid())
  sopId           String
  sop             Sop      @relation(fields: [sopId], references: [id], onDelete: Cascade)
  version         Int
  status          SopStatus @default(DRAFT)
  changes         String?
  content         Json
  outline         Json?
  sla             Json?
  complianceFindings Json?
  riskFindings      Json?
  auditFindings     Json?
  complianceScore   Int?
  riskScore          Int?
  auditReadinessScore Int?

  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  approvals    SopApproval[]
  risks         SopRiskItem[]
  complianceItems SopComplianceItem[]
  artifacts     SopArtifact[]
  auditEvents   SopAuditEvent[]

  @@unique([sopId, version])
  @@index([sopId, version])
  @@map("sop_versions")
}

model SopApproval {
  id          String              @id @default(cuid())
  versionId   String
  version     SopVersion         @relation(fields: [versionId], references: [id], onDelete: Cascade)
  approverRole String
  approverName String?
  order       Int                 @default(1)
  status      SopApprovalStatus @default(PENDING)
  comment     String?
  decidedBy   String?
  decidedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([versionId, status])
  @@index([versionId, order])
  @@map("sop_approvals")
}

model SopRiskItem {
  id          String   @id @default(cuid())
  versionId   String
  version     SopVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  riskLevel   String
  risk        String
  likelihood  String?
  impact      String?
  mitigation  String?
  createdAt   DateTime @default(now())

  @@index([versionId])
  @@map("sop_risks")
}

model SopComplianceItem {
  id           String   @id @default(cuid())
  versionId    String
  version      SopVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  requirement  String
  regulation   String?
  control      String?
  status       String?
  createdAt    DateTime @default(now())

  @@index([versionId])
  @@map("sop_compliance_items")
}

model SopAuditEvent {
  id          String   @id @default(cuid())
  versionId   String
  version     SopVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  actor       String
  action      String
  evidence    Json?
  createdAt   DateTime @default(now())

  @@index([versionId, createdAt(sort: Desc)])
  @@map("sop_audit_events")
}

model SopArtifact {
  id          String          @id @default(cuid())
  versionId   String
  version     SopVersion      @relation(fields: [versionId], references: [id], onDelete: Cascade)
  type        SopArtifactType
  title       String?
  content     String
  createdAt   DateTime @default(now())

  @@index([versionId, type])
  @@map("sop_artifacts")
}

model LocationRecord {
  id           String         @id @default(cuid())
  employeeId   String
  employee     Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  latitude     Float
  longitude    Float
  accuracy     Float?
  timestamp    DateTime       @default(now())
  source       LocationSource @default(GPS)
  batteryLevel Float?
  address      String?

  @@index([employeeId, timestamp(sort: Desc)])
  @@map("location_records")
}

model Geofence {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  type         String
  coordinates  Json // [[lat,lng], ...]
  radius       Float?
  isActive     Boolean @default(true)
  alertOnEntry Boolean @default(false)
  alertOnExit  Boolean @default(true)

  @@map("geofences")
}

model LocationAlert {
  id         String        @id @default(cuid())
  employeeId String
  employee   Employee      @relation(fields: [employeeId], references: [id])
  type       AlertType
  severity   AlertSeverity
  message    String
  location   Json // LocationData
  geofenceId String?
  isResolved Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([employeeId, isResolved])
  @@map("location_alerts")
}

model WorkerLocationSettings {
  id                       String    @id @default(cuid())
  employeeId               String    @unique
  employee                 Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  trackingEnabled          Boolean   @default(false)
  consentGiven             Boolean   @default(false)
  consentDate              DateTime?
  updateFrequency          Int       @default(5) // minutes
  privacyLevel             String    @default("standard")
  emergencyContactsEnabled Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@map("worker_location_settings")
}

model EmergencyAlert {
  id            String        @id @default(cuid())
  employeeId    String
  employee      Employee      @relation(fields: [employeeId], references: [id])
  type          EmergencyType
  status        String        @default("active")
  message       String?
  location      Json
  responderId   String?
  responseTime  String?
  createdAt     DateTime      @default(now())
  resolvedAt    DateTime?

  @@index([status])
  @@map("emergency_alerts")
}

enum CandidateStatus {
  NEW
  SHORTLISTED
  SCREENING
  CONSIDER
  SUSPENDED
  HIRED
}

model Candidate {
  id             String           @id @default(cuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fullName       String
  email           String?
  phone           String?
  nationality     String?
  country        String?
  positionApplied String?

  resumeUrl      String?
  resumeText     String?

  parsedProfile  Json?
  status         CandidateStatus @default(NEW)

  backgroundCheck Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, fullName])
  @@map("candidates")
}

