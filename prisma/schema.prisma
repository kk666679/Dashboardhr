// This is your Prisma schema file for AI-HRMS
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model complianceDeadline {
  id        String   @id @default(cuid())
  title     String
  dueDate   DateTime
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model training {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  participants Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
